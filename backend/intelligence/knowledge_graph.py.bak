class ThreatKnowledgeGraph:
    """In-memory threat knowledge graph."""

    def __init__(self):
        self.G = nx.DiGraph()
        self._build_graph()

    def _build_graph(self):
        # Add threat actors
        for actor in THREAT_ACTORS:
            self.G.add_node(actor["id"], type="ThreatActor", **actor)

        # Add campaigns
        for camp in CAMPAIGNS:
            self.G.add_node(camp["id"], type="Campaign", **camp)
            # Link campaign to actor
            if camp.get("actor_id"):
                self.G.add_edge(camp["id"], camp["actor_id"], relationship="ATTRIBUTED_TO")

        # Add domains
        for dom in DOMAINS:
            self.G.add_node(dom["id"], type="Domain", **dom)
            # Link domain to campaign
            for camp in CAMPAIGNS:
                if dom["fqdn"] in camp.get("iocs", {}).get("domains", []):
                    self.G.add_edge(camp["id"], dom["id"], relationship="USES_DOMAIN")

        # Add IPs
        for ip in IPS:
            self.G.add_node(ip["id"], type="IPAddress", **ip)
            # Link IP to campaign
            for camp in CAMPAIGNS:
                if ip["ip"] in camp.get("iocs", {}).get("ips", []):
                    self.G.add_edge(camp["id"], ip["id"], relationship="USES_IP")

    def get_graph_data(self, depth: int = 2, entity_type: Optional[str] = None) -> dict:
        """Return graph data for D3.js visualization."""
        nodes = []
        edges = []

        for node_id, data in self.G.nodes(data=True):
            if entity_type and data.get("type", "").lower() != entity_type.lower():
                continue
            nodes.append({
                "id": node_id,
                "label": data.get("name") or data.get("fqdn") or data.get("ip") or node_id,
                "type": data.get("type", "Unknown"),
                "risk": data.get("risk", "medium"),
                "data": {k: v for k, v in data.items() if k not in ("id",)},
            })

        for src, tgt, edata in self.G.edges(data=True):
            edges.append({
                "source": src,
                "target": tgt,
                "relationship": edata.get("relationship", "RELATED_TO"),
            })

        return {"nodes": nodes, "edges": edges, "total_nodes": len(nodes), "total_edges": len(edges)}

    def get_actor(self, actor_id: str) -> Optional[dict]:
        if actor_id in self.G.nodes:
            return dict(self.G.nodes[actor_id])
        # Try by name
        for nid, data in self.G.nodes(data=True):
            if data.get("type") == "ThreatActor" and data.get("name", "").lower() == actor_id.lower():
                return dict(data)
        return None

    def get_campaign(self, campaign_id: str) -> Optional[dict]:
        if campaign_id in self.G.nodes:
            return dict(self.G.nodes[campaign_id])
        return None

    def correlate_iocs(self, domains: list = None, ips: list = None, hashes: list = None) -> dict:
        """Find campaigns matching the provided IOCs."""
        matches = []
        related_campaigns = []
        risk_elevation = 0.0

        domains = domains or []
        ips = ips or []
        hashes = hashes or []

        for camp in CAMPAIGNS:
            camp_domains = camp.get("iocs", {}).get("domains", [])
            camp_ips = camp.get("iocs", {}).get("ips", [])
            camp_hashes = camp.get("iocs", {}).get("hashes", [])

            domain_matches = [d for d in domains if d in camp_domains]
            ip_matches = [i for i in ips if i in camp_ips]
            hash_matches = [h for h in hashes if h in camp_hashes]

            total_matches = len(domain_matches) + len(ip_matches) + len(hash_matches)
            if total_matches > 0:
                matches.append({
                    "campaign_id": camp["id"],
                    "campaign_name": camp["name"],
                    "actor": camp["actor"],
                    "matched_iocs": {
                        "domains": domain_matches,
                        "ips": ip_matches,
                        "hashes": hash_matches,
                    },
                    "match_count": total_matches,
                    "risk_level": camp["risk_level"],
                })
                related_campaigns.append(camp["id"])
                if camp["risk_level"] == "critical":
                    risk_elevation = max(risk_elevation, 0.20)
                elif camp["risk_level"] == "high":
                    risk_elevation = max(risk_elevation, 0.12)

        return {
            "matches": matches,
            "related_campaigns": related_campaigns,
            "risk_elevation": round(risk_elevation, 4),
            "ioc_count_checked": len(domains) + len(ips) + len(hashes),
        }

    def get_all_campaigns(self) -> list:
        return CAMPAIGNS

    def get_all_actors(self) -> list:
        return THREAT_ACTORS

    def search(self, query: str) -> dict:
        """Search graph nodes by text query."""
        query_lower = query.lower()
        results = {"actors": [], "campaigns": [], "domains": [], "ips": []}

        for nid, data in self.G.nodes(data=True):
            node_str = str(data).lower()
            if query_lower in node_str:
                t = data.get("type", "")
                if t == "ThreatActor":
                    results["actors"].append({"id": nid, "name": data.get("name"), "risk": data.get("risk")})
                elif t == "Campaign":
                    results["campaigns"].append({"id": nid, "name": data.get("name"), "actor": data.get("actor")})
                elif t == "Domain":
                    results["domains"].append({"id": nid, "fqdn": data.get("fqdn")})
                elif t == "IPAddress":
                    results["ips"].append({"id": nid, "ip": data.get("ip")})

        return results


# Singleton
_graph_instance: Optional[ThreatKnowledgeGraph] = None


def get_graph() -> ThreatKnowledgeGraph:
    global _graph_instance
    if _graph_instance is None:
        _graph_instance = ThreatKnowledgeGraph()
    return _graph_instance
